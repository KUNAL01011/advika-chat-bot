{
  "name": "aurix-music-bot",
  "version": "2.0.0",
  "description": "Aurix — Discord music bot using discord-player. Multi-VC, 24/7, Render hosted.",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "postinstall": "node -e \"require('fs').writeFileSync('./node_modules/discord-voip/dist/index.js', 'module.exports = require(\\\"@discordjs/voice\\\");')\""
  },
  "dependencies": {
    "@discord-player/extractor": "^4.5.0",
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.19.2",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "discord-player": "^6.6.10",
    "discord-player-youtubei": "2.0.0",
    "discord.js": "^14.15.0",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "ffmpeg-static": "^5.3.0",
    "mediaplex": "^1.0.0",
    "node-cron": "^3.0.3",
    "sodium-native": "^4.3.1",
    "youtube-dl-exec": "^3.1.7"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
